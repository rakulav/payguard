# Anthropic API (required for real LLM calls; leave placeholder only in commits)
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-replace-in-local-env

# 1 = canned traces only (no billing); 0 = live Claude
MOCK_LLM=0

# Postgres (defaults match docker-compose; override in production)
POSTGRES_USER=payguard
POSTGRES_PASSWORD=payguard_secret
POSTGRES_DB=payguard
DATABASE_URL=postgresql+asyncpg://payguard:payguard_secret@postgres:5432/payguard
DATABASE_URL_SYNC=postgresql://payguard:payguard_secret@postgres:5432/payguard

# Qdrant vector DB (service name inside Compose network)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# API bind
API_HOST=0.0.0.0
API_PORT=8000

# Browser-facing API URL for Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# Embeddings (FastEmbed / seed pipeline)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
