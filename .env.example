# PayGuard Environment Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here
MOCK_LLM=0

# Postgres
POSTGRES_USER=payguard
POSTGRES_PASSWORD=payguard_secret
POSTGRES_DB=payguard
DATABASE_URL=postgresql+asyncpg://payguard:payguard_secret@postgres:5432/payguard
DATABASE_URL_SYNC=postgresql://payguard:payguard_secret@postgres:5432/payguard

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Embedding model (CPU-friendly)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
